# Copy this file to .env for local development. Never commit the real .env file.
VETICARE_APP_NAME=VetiCare API
VETICARE_ENVIRONMENT=development
VETICARE_DEBUG=true
VETICARE_API_V1_PREFIX=/api/v1
VETICARE_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173","http://127.0.0.1:3000"]
VETICARE_SECRET_KEY=replace-with-a-long-random-development-secret
VETICARE_DATABASE_URL=postgresql+psycopg://postgres:DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
VETICARE_ACCESS_TOKEN_EXPIRE_MINUTES=30
VETICARE_GOOGLE_PLACES_API_KEY=your-google-places-api-key-here
VETICARE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VETICARE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
VETICARE_SUPABASE_SECRET_KEY=your-service-role-key-here
VETICARE_SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
