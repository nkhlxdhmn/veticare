# =========================================================================
# Veticare FastAPI Environment Variables Config Template
# Copy this file to .env and fill in configuration credentials.
# =========================================================================

# Database Config
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=veticare
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/veticare

# JWT Authentication Config
# Generate using: openssl rand -hex 32
JWT_SECRET_KEY=yoursecretkeyhere
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Supabase API Integration (Optional / Blob Storage)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET_NAME=pet-images

# Application Config
APP_NAME=VetiCare
DEBUG=true
ALLOWED_HOSTS=["*"]
