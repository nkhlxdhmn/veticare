# Application
APP_NAME="VetiCare API"
ENVIRONMENT="development"
VETICARE_DEBUG="true"

# Database
DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/veticare"

# Authentication -- replace with a long random value before production
SECRET_KEY="change-me-before-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# Web security (JSON arrays)
CORS_ORIGINS='["http://localhost:3000"]'
TRUSTED_HOSTS='["localhost", "127.0.0.1"]'
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
