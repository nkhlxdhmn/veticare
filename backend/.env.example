# Copy this file to .env for local development. Never commit the real .env file.
VETICARE_APP_NAME=VetiCare API
VETICARE_ENVIRONMENT=development
VETICARE_DEBUG=true
VETICARE_API_V1_PREFIX=/api/v1
VETICARE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
VETICARE_SECRET_KEY=replace-with-a-long-random-development-secret
VETICARE_DATABASE_URL=postgresql+psycopg://postgres:password@db.project-ref.supabase.co:5432/postgres?sslmode=require
VETICARE_ACCESS_TOKEN_EXPIRE_MINUTES=30
