# Copy this file to .env for local development
VITE_API_URL=http://localhost:8000
# AI Assistant backend (separate service, can differ from main API)
VITE_AI_API_URL=http://localhost:8000
#
# ── Production (Vercel Dashboard) ──────────────────────────────────────
# Set these env vars in the Vercel dashboard (Settings → Environment Variables):
#
#   VITE_API_URL      = https://veticare.onrender.com
#   VITE_AI_API_URL   = https://veticare.onrender.com
#
# Do NOT include a path suffix — the API client appends /api/ai-assistant etc.
# (AI routes are now merged into the main backend; both use the same URL.)
